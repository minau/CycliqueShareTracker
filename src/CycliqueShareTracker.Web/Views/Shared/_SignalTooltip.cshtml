@model CycliqueShareTracker.Web.Models.SignalTooltipViewModel

<div class="signal-tooltip-content" role="tooltip">
    <h4>@Model.Title</h4>
    <p class="signal-tooltip-score">Score: @(Model.Score?.ToString() ?? "N/A") / 100</p>
    <ul class="signal-tooltip-factors">
        @foreach (var factor in Model.Factors)
        {
            <li class="@(factor.Triggered ? "triggered" : "not-triggered")">
                <span class="factor-points">+@factor.Points</span>
                <span class="factor-label">@factor.Label</span>
            </li>
        }
    </ul>
    <p class="signal-tooltip-reason">@Model.PrimaryReason</p>
</div>
