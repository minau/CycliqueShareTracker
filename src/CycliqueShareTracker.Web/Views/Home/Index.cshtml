@model WatchlistViewModel

<section class="card">
    <h2>Watchlist cyclique (MVP5)</h2>
    <form method="get" asp-action="Index" class="watchlist-toolbar">
        <label>
            Tri
            <select name="sortBy" onchange="this.form.submit()">
                <option value="buy" selected="@(Model.SortBy == "buy")">Buy score décroissant</option>
                <option value="sell" selected="@(Model.SortBy == "sell")">Sell score décroissant</option>
                <option value="name" selected="@(Model.SortBy == "name")">Nom</option>
                <option value="ticker" selected="@(Model.SortBy == "ticker")">Ticker</option>
            </select>
        </label>
        <label>
            Filtre
            <select name="filter" onchange="this.form.submit()">
                <option value="all" selected="@(Model.Filter == "all")">Toutes</option>
                <option value="buy" selected="@(Model.Filter == "buy")">Buy candidates</option>
                <option value="sell" selected="@(Model.Filter == "sell")">Sell candidates</option>
                <option value="neutral" selected="@(Model.Filter == "neutral")">Neutres</option>
            </select>
        </label>
        <input type="hidden" id="includeMacdInScoringHidden" name="includeMacdInScoring" value="@(Model.IncludeMacdInScoring ? "true" : "false")" />
        <label>
            <input type="checkbox"
                   @(Model.IncludeMacdInScoring ? "checked" : null)
                   onchange="document.getElementById('includeMacdInScoringHidden').value = this.checked ? 'true' : 'false'; this.form.submit()" />
            MACD dans le scoring
        </label>
    </form>

    <p>Top Buy candidate: <strong>@(Model.TopBuySymbol ?? "N/A")</strong> | Top Sell candidate: <strong>@(Model.TopSellSymbol ?? "N/A")</strong></p>
</section>

<section class="card">
    <table>
        <thead>
            <tr>
                <th>Action</th>
                <th>Secteur</th>
                <th>Prix</th>
                <th>SMA50</th>
                <th>SMA200</th>
                <th>RSI14</th>
                <th>Drawdown 52w</th>
                <th>Buy score</th>
                <th>Sell score</th>
                <th>Statut</th>
                <th>Raison clé</th>
                <th>Détail</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><strong>@item.Name</strong><br />@item.Symbol</td>
                    <td>@item.Sector</td>
                    <td>@(item.LastClose?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Sma50?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Sma200?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Rsi14?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Drawdown52WeeksPercent?.ToString("F2") ?? "N/A")%</td>
                    <td>@(item.BuyScore?.ToString() ?? "N/A")</td>
                    <td>@(item.SellScore?.ToString() ?? "N/A")</td>
                    <td>@item.Status</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.Error))
                        {
                            <span>@item.Error</span>
                        }
                        else
                        {
                            <span>@item.PrimaryReason</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="Home"
                           asp-action="Detail"
                           asp-route-symbol="@item.Symbol"
                           asp-route-includeMacdInScoring="@Model.IncludeMacdInScoring">Ouvrir</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<form asp-action="Refresh" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="includeMacdInScoring" value="@Model.IncludeMacdInScoring" />
    <button type="submit">Lancer une mise à jour manuelle</button>
</form>
