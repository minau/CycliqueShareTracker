@model DashboardViewModel
@using System.Text.Json

@if (!string.IsNullOrWhiteSpace(Model.Notice))
{
    <section class="card">
        <p>@Model.Notice</p>
    </section>
}

<section class="grid">
    <div class="card">
        <h2>@Model.AssetName (@Model.AssetSymbol)</h2>
        <p>Dernière mise à jour: @Model.LastUpdateDate</p>
        <p>Dernier prix: @(Model.LastClose?.ToString("F2") ?? "N/A")</p>
        <p>Variation jour: @(Model.DayChangePercent?.ToString("F2") ?? "N/A")%</p>
    </div>

    <div class="card">
        <h3>Signal d'entrée</h3>
        <div class="signal-tooltip">
            <p class="signal signal-trigger" tabindex="0">@Model.Signal</p>
            <partial name="_SignalTooltip" model="Model.EntryTooltip" />
        </div>
        <p>Score: @(Model.Score?.ToString() ?? "N/A") / 100</p>
    </div>


    <div class="card">
        <h3>Signal de sortie</h3>
        <div class="signal-tooltip">
            <p class="signal signal-trigger" tabindex="0">@Model.ExitSignal</p>
            <partial name="_SignalTooltip" model="Model.ExitTooltip" />
        </div>
        <p>Exit score: @(Model.ExitScore?.ToString() ?? "N/A") / 100</p>
        <p>Raison principale: @Model.ExitPrimaryReason</p>
    </div>

    <div class="card">
        <h3>Indicateurs</h3>
        <ul>
            <li>SMA50: @(Model.Sma50?.ToString("F2") ?? "N/A")</li>
            <li>SMA200: @(Model.Sma200?.ToString("F2") ?? "N/A")</li>
            <li>RSI14: @(Model.Rsi14?.ToString("F2") ?? "N/A")</li>
            <li>Drawdown 52w: @(Model.Drawdown52WeeksPercent?.ToString("F2") ?? "N/A")%</li>
        </ul>
    </div>
</section>

<form asp-action="Refresh" method="post">
    @Html.AntiForgeryToken()
    <button type="submit">Lancer une mise à jour manuelle</button>
</form>

<section class="card">
    <div class="section-header">
        <h3>Bougies & tendances (SMA50 / SMA200)</h3>
        <a asp-controller="Home" asp-action="SignalHistory">Voir l'historique des signaux</a>
    </div>
    <div class="chart-stack">
        <canvas id="priceChart" height="110"></canvas>
        <canvas id="rsiChart" height="42"></canvas>
    </div>
</section>

<section class="card">
    <h3>Historique récent</h3>
    <table>
        <thead>
            <tr>
                <th>Date</th><th>Open</th><th>High</th><th>Low</th><th>Close</th><th>Volume</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.RecentPrices)
        {
            <tr>
                <td>@row.Date</td>
                <td>@row.Open.ToString("F2")</td>
                <td>@row.High.ToString("F2")</td>
                <td>@row.Low.ToString("F2")</td>
                <td>@row.Close.ToString("F2")</td>
                <td>@row.Volume</td>
            </tr>
        }
        </tbody>
    </table>
</section>

@{
    var chartDataJson = JsonSerializer.Serialize(Model.ChartPoints);
}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
<script>
    (() => {
        const points = @Html.Raw(chartDataJson);
        if (!points || points.length === 0) {
            return;
        }

        const labels = points.map(x => x.Date);
        const candleBodies = points.map(x => [Number(x.Open), Number(x.Close)]);
        const candleColors = points.map(x => Number(x.Close) >= Number(x.Open) ? '#16a34a' : '#dc2626');
        const wickData = [];
        const rsiData = points.map(x => x.Rsi14 === null ? null : Number(x.Rsi14));

        points.forEach(x => {
            wickData.push({ x: x.Date, y: Number(x.Low) });
            wickData.push({ x: x.Date, y: Number(x.High) });
            wickData.push({ x: x.Date, y: null });
        });

        const yPaddingRatio = 0;
        const minYSpanAbsolute = 0.01;
        const minYSpanRatio = 0.002;
        const yUpdateEpsilon = 0.0001;

        let lastAppliedYMin = null;
        let lastAppliedYMax = null;

        const toFiniteNumberOrNull = value => {
            if (value === null || value === undefined) {
                return null;
            }

            const parsed = Number(value);
            return Number.isFinite(parsed) ? parsed : null;
        };

        const setYScaleToVisibleRange = (chart, refreshChart = false) => {
            const xScale = chart.scales.x;
            const yScale = chart.scales.y;
            if (!xScale || !yScale) {
                return;
            }

            const xMin = Number(xScale.min);
            const xMax = Number(xScale.max);
            if (Number.isNaN(xMin) || Number.isNaN(xMax)) {
                return;
            }

            const startIndex = Math.max(0, Math.floor(xMin));
            const endIndex = Math.min(points.length - 1, Math.ceil(xMax));
            if (startIndex > endIndex) {
                return;
            }

            let visibleMin = Number.POSITIVE_INFINITY;
            let visibleMax = Number.NEGATIVE_INFINITY;

            for (let i = startIndex; i <= endIndex; i++) {
                const candidateValues = [
                    toFiniteNumberOrNull(points[i].Low),
                    toFiniteNumberOrNull(points[i].High),
                    toFiniteNumberOrNull(points[i].Open),
                    toFiniteNumberOrNull(points[i].Close),
                    toFiniteNumberOrNull(points[i].Sma50),
                    toFiniteNumberOrNull(points[i].Sma200)
                ];

                for (const value of candidateValues) {
                    if (value === null) {
                        continue;
                    }

                    visibleMin = Math.min(visibleMin, value);
                    visibleMax = Math.max(visibleMax, value);
                }
            }

            if (!Number.isFinite(visibleMin) || !Number.isFinite(visibleMax)) {
                return;
            }

            const center = (visibleMax + visibleMin) / 2;
            const dynamicMinYSpan = Math.max(Math.abs(center) * minYSpanRatio, minYSpanAbsolute);

            let span = visibleMax - visibleMin;
            if (span < dynamicMinYSpan) {
                span = dynamicMinYSpan;
                visibleMin = center - (span / 2);
                visibleMax = center + (span / 2);
            }

            const padding = span * yPaddingRatio;
            const targetMin = visibleMin - padding;
            const targetMax = visibleMax + padding;

            const minDiff = lastAppliedYMin === null ? Number.POSITIVE_INFINITY : Math.abs(targetMin - lastAppliedYMin);
            const maxDiff = lastAppliedYMax === null ? Number.POSITIVE_INFINITY : Math.abs(targetMax - lastAppliedYMax);
            if (minDiff < yUpdateEpsilon && maxDiff < yUpdateEpsilon) {
                return;
            }

            chart.options.scales.y.min = targetMin;
            chart.options.scales.y.max = targetMax;
            lastAppliedYMin = targetMin;
            lastAppliedYMax = targetMax;

            if (refreshChart) {
                chart.update('none');
            }
        };

        const syncXAxis = (sourceChart, targetChart) => {
            const sourceScale = sourceChart.scales.x;
            if (!sourceScale) {
                return;
            }

            targetChart.options.scales.x.min = sourceScale.min;
            targetChart.options.scales.x.max = sourceScale.max;
            targetChart.update('none');
        };

        const syncHover = (sourceChart, targetChart, activeElements) => {
            if (!targetChart) {
                return;
            }

            if (!activeElements || activeElements.length === 0) {
                targetChart.setActiveElements([]);
                targetChart.tooltip.setActiveElements([], { x: 0, y: 0 });
                targetChart.update('none');
                return;
            }

            const first = activeElements[0];
            const mapped = targetChart.data.datasets
                .map((_, datasetIndex) => ({ datasetIndex, index: first.index }))
                .filter(({ datasetIndex, index }) => targetChart.getDatasetMeta(datasetIndex).data[index]);

            targetChart.setActiveElements(mapped);
            targetChart.tooltip.setActiveElements(mapped, { x: first.element.x, y: first.element.y });
            targetChart.update('none');
        };

        const sharedZoomPluginOptions = (currentChart, siblingChart, shouldAdjustYAxis) => ({
            pan: {
                enabled: true,
                mode: 'x',
                onPan: () => {
                    if (shouldAdjustYAxis) {
                        setYScaleToVisibleRange(currentChart, true);
                    }
                    syncXAxis(currentChart, siblingChart);
                },
                onPanComplete: () => {
                    if (shouldAdjustYAxis) {
                        setYScaleToVisibleRange(currentChart, true);
                    }
                    syncXAxis(currentChart, siblingChart);
                }
            },
            zoom: {
                wheel: {
                    enabled: true
                },
                pinch: {
                    enabled: true
                },
                mode: 'x',
                onZoom: () => {
                    if (shouldAdjustYAxis) {
                        setYScaleToVisibleRange(currentChart, true);
                    }
                    syncXAxis(currentChart, siblingChart);
                },
                onZoomComplete: () => {
                    if (shouldAdjustYAxis) {
                        setYScaleToVisibleRange(currentChart, true);
                    }
                    syncXAxis(currentChart, siblingChart);
                }
            },
            limits: {
                x: {
                    minRange: 10
                }
            }
        });

        let priceChart;
        let rsiChart;

        priceChart = new Chart(document.getElementById('priceChart'), {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    {
                        label: 'Bougies',
                        data: candleBodies,
                        backgroundColor: candleColors,
                        borderColor: candleColors,
                        borderWidth: 1,
                        borderSkipped: false,
                        barPercentage: 0.7,
                        categoryPercentage: 0.9,
                        order: 2
                    },
                    {
                        label: 'Mèches',
                        type: 'line',
                        data: wickData,
                        borderColor: '#374151',
                        borderWidth: 1,
                        pointRadius: 0,
                        spanGaps: false,
                        parsing: true,
                        order: 1
                    },
                    {
                        label: 'SMA 50',
                        type: 'line',
                        data: points.map(x => x.Sma50 === null ? null : Number(x.Sma50)),
                        borderColor: '#2563eb',
                        borderWidth: 2,
                        pointRadius: 0,
                        spanGaps: true,
                        tension: 0.15,
                        order: 0
                    },
                    {
                        label: 'SMA 200',
                        type: 'line',
                        data: points.map(x => x.Sma200 === null ? null : Number(x.Sma200)),
                        borderColor: '#f59e0b',
                        borderWidth: 2,
                        pointRadius: 0,
                        spanGaps: true,
                        tension: 0.15,
                        order: 0
                    },
                    {
                        label: 'BUY ZONE',
                        type: 'line',
                        data: points.map(x => x.IsBuyZone ? Number(x.Close) : null),
                        showLine: false,
                        pointRadius: 4,
                        pointHoverRadius: 5,
                        backgroundColor: '#7c3aed',
                        borderColor: '#7c3aed',
                        borderWidth: 1,
                        order: -10
                    },
                    {
                        label: 'SELL ZONE',
                        type: 'line',
                        data: points.map(x => x.IsSellZone ? Number(x.Close) : null),
                        showLine: false,
                        pointStyle: 'triangle',
                        pointRadius: 6,
                        pointHoverRadius: 7,
                        backgroundColor: '#f59e0b',
                        borderColor: '#f59e0b',
                        borderWidth: 1,
                        order: -10
                    }
                ]
            },
            options: {
                maintainAspectRatio: true,
                interaction: { mode: 'index', intersect: false },
                onHover: (_, activeElements, chart) => syncHover(chart, rsiChart, activeElements),
                plugins: {
                    legend: { position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: (context) => {
                                const point = points[context.dataIndex];
                                if (!point) {
                                    return context.formattedValue;
                                }

                                if (context.dataset.label === 'BUY ZONE' && point.IsBuyZone) {
                                    const lines = [`BUY ZONE - score: ${point.EntryScore ?? 'N/A'}/100`];
                                    (point.EntryScoreFactors ?? []).forEach(f => {
                                        const marker = f.Triggered ? '✓' : '×';
                                        lines.push(`${marker} +${f.Points} ${f.Label}`);
                                    });
                                    lines.push(`Raison: ${point.EntryPrimaryReason ?? 'N/A'}`);
                                    return lines;
                                }

                                if (context.dataset.label === 'SELL ZONE' && point.IsSellZone) {
                                    const lines = [`SELL ZONE - score: ${point.ExitScore ?? 'N/A'}/100`];
                                    (point.ExitScoreFactors ?? []).forEach(f => {
                                        const marker = f.Triggered ? '✓' : '×';
                                        lines.push(`${marker} +${f.Points} ${f.Label}`);
                                    });
                                    lines.push(`Raison: ${point.ExitPrimaryReason ?? 'N/A'}`);
                                    return lines;
                                }

                                return `${context.dataset.label}: ${context.formattedValue}`;
                            }
                        }
                    },
                    zoom: {}
                },
                scales: {
                    x: {
                        ticks: { maxTicksLimit: 8 }
                    },
                    y: {}
                }
            }
        });

        rsiChart = new Chart(document.getElementById('rsiChart'), {
            type: 'line',
            data: {
                labels,
                datasets: [
                    {
                        label: 'RSI 14',
                        data: rsiData,
                        borderColor: '#9333ea',
                        borderWidth: 2,
                        pointRadius: 0,
                        spanGaps: true,
                        tension: 0.15
                    },
                    {
                        label: 'Seuil 70',
                        data: labels.map(() => 70),
                        borderColor: '#dc2626',
                        borderDash: [5, 5],
                        borderWidth: 1,
                        pointRadius: 0
                    },
                    {
                        label: 'Seuil 30',
                        data: labels.map(() => 30),
                        borderColor: '#16a34a',
                        borderDash: [5, 5],
                        borderWidth: 1,
                        pointRadius: 0
                    }
                ]
            },
            options: {
                maintainAspectRatio: true,
                interaction: { mode: 'index', intersect: false },
                onHover: (_, activeElements, chart) => syncHover(chart, priceChart, activeElements),
                plugins: {
                    legend: { position: 'top' },
                    zoom: {}
                },
                scales: {
                    x: {
                        ticks: { maxTicksLimit: 8 }
                    },
                    y: {
                        min: 0,
                        max: 100,
                        ticks: {
                            stepSize: 10
                        }
                    }
                }
            }
        });

        priceChart.options.plugins.zoom = sharedZoomPluginOptions(priceChart, rsiChart, true);
        rsiChart.options.plugins.zoom = sharedZoomPluginOptions(rsiChart, priceChart, false);

        setYScaleToVisibleRange(priceChart, true);
        syncXAxis(priceChart, rsiChart);
    })();
</script>
