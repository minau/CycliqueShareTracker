@model WatchlistViewModel

<section class="card">
    <h2>Watchlist cyclique (MVP5)</h2>
    <form method="get" asp-action="Index" class="watchlist-toolbar">
        <label>
            Algorithme
            <select name="algorithmType" onchange="this.form.submit()">
                @foreach (var algo in Enum.GetNames(typeof(CycliqueShareTracker.Application.Models.AlgorithmType)))
                {
                    if (algo == Model.ActiveAlgorithmType)
                    {
                        <option value="@algo" selected>@algo</option>
                    }
                    else
                    {
                        <option value="@algo">@algo</option>
                    }
                }
            </select>
        </label>
        <label>
            Tri
            <select name="sortBy" onchange="this.form.submit()">
                <option value="ticker" selected="@(Model.SortBy == "ticker")">Ticker</option>
                <option value="name" selected="@(Model.SortBy == "name")">Nom</option>
            </select>
        </label>
    </form>

    <p>Algorithme actif: <strong>@Model.ActiveAlgorithmName</strong></p>
</section>

<section class="card">
    <table>
        <thead>
            <tr>
                <th>Action</th>
                <th>Secteur</th>
                <th>Prix</th>
                <th>SMA50</th>
                <th>SMA200</th>
                <th>RSI14</th>
                <th>Drawdown 52w</th>
                <th>Détail</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><strong>@item.Name</strong><br />@item.Symbol</td>
                    <td>@item.Sector</td>
                    <td>@(item.LastClose?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Sma50?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Sma200?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Rsi14?.ToString("F2") ?? "N/A")</td>
                    <td>@(item.Drawdown52WeeksPercent?.ToString("F2") ?? "N/A")%</td>
                    <td>
                        <a asp-controller="Home"
                           asp-action="Detail"
                           asp-route-symbol="@item.Symbol"
                           asp-route-algorithmType="@Model.ActiveAlgorithmType">Ouvrir</a>
                    </td>
                </tr>
                @if (!string.IsNullOrWhiteSpace(item.Error))
                {
                    <tr>
                        <td colspan="8">@item.Error</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>

<form asp-action="Refresh" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="algorithmType" value="@Model.ActiveAlgorithmType" />
    <button type="submit">Lancer une mise à jour manuelle</button>
</form>
