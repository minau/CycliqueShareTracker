@model DashboardViewModel
@using System.Text.Json

@if (!string.IsNullOrWhiteSpace(Model.Notice))
{
    <section class="card">
        <p>@Model.Notice</p>
    </section>
}

<section class="grid">
    <div class="card">
        <h2>@Model.AssetName (@Model.AssetSymbol)</h2>
        <p>Dernière mise à jour: @Model.LastUpdateDate</p>
        <p>Dernier prix: @(Model.LastClose?.ToString("F2") ?? "N/A")</p>
        <p>Variation jour: @(Model.DayChangePercent?.ToString("F2") ?? "N/A")%</p>
    </div>

    <div class="card">
        <h3>Signal</h3>
        <p class="signal">@Model.Signal</p>
        <p>Score: @(Model.Score?.ToString() ?? "N/A") / 100</p>
    </div>

    <div class="card">
        <h3>Indicateurs</h3>
        <ul>
            <li>SMA50: @(Model.Sma50?.ToString("F2") ?? "N/A")</li>
            <li>SMA200: @(Model.Sma200?.ToString("F2") ?? "N/A")</li>
            <li>RSI14: @(Model.Rsi14?.ToString("F2") ?? "N/A")</li>
            <li>Drawdown 52w: @(Model.Drawdown52WeeksPercent?.ToString("F2") ?? "N/A")%</li>
        </ul>
    </div>
</section>

<form asp-action="Refresh" method="post">
    @Html.AntiForgeryToken()
    <button type="submit">Lancer une mise à jour manuelle</button>
</form>

<section class="card">
    <div class="section-header">
        <h3>Prix & tendances (SMA50 / SMA200)</h3>
        <a asp-controller="Home" asp-action="SignalHistory">Voir l'historique des signaux</a>
    </div>
    <canvas id="priceChart" height="110"></canvas>
</section>

<section class="card">
    <h3>Historique récent</h3>
    <table>
        <thead>
            <tr>
                <th>Date</th><th>Open</th><th>High</th><th>Low</th><th>Close</th><th>Volume</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.RecentPrices)
        {
            <tr>
                <td>@row.Date</td>
                <td>@row.Open.ToString("F2")</td>
                <td>@row.High.ToString("F2")</td>
                <td>@row.Low.ToString("F2")</td>
                <td>@row.Close.ToString("F2")</td>
                <td>@row.Volume</td>
            </tr>
        }
        </tbody>
    </table>
</section>

@{
    var chartDataJson = JsonSerializer.Serialize(Model.ChartPoints);
}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
    (() => {
        const points = @Html.Raw(chartDataJson);
        if (!points || points.length === 0) {
            return;
        }

        const labels = points.map(x => x.Date);
        const buyZonePoints = points.map(x => x.IsBuyZone ? x.Close : null);
        new Chart(document.getElementById('priceChart'), {
            type: 'line',
            data: {
                labels,
                datasets: [
                    { label: 'Close', data: points.map(x => x.Close), borderColor: '#111827', borderWidth: 2, pointRadius: 0, tension: 0.15 },
                    { label: 'SMA 50', data: points.map(x => x.Sma50), borderColor: '#2563eb', borderWidth: 2, pointRadius: 0, tension: 0.15 },
                    { label: 'SMA 200', data: points.map(x => x.Sma200), borderColor: '#f59e0b', borderWidth: 2, pointRadius: 0, tension: 0.15 },
                    { label: 'BUY ZONE', data: buyZonePoints, showLine: false, pointRadius: 4, pointHoverRadius: 5, backgroundColor: '#16a34a', borderColor: '#16a34a' }
                ]
            },
            options: {
                maintainAspectRatio: true,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { position: 'top' } },
                scales: {
                    x: {
                        ticks: { maxTicksLimit: 8 }
                    }
                }
            }
        });
    })();
</script>
