@model SignalHistoryViewModel

<section class="card">
    <div class="section-header">
        <h2>Historique des signaux - @Model.AssetName (@Model.AssetSymbol)</h2>
        <div class="section-header-links">
            <a asp-controller="Home" asp-action="Index" asp-route-includeMacdInScoring="@Model.IncludeMacdInScoring">Retour au dashboard</a>
            <a asp-controller="Home" asp-action="Documentation" asp-route-includeMacdInScoring="@Model.IncludeMacdInScoring">Documentation</a>
        </div>
    </div>
</section>

<section class="card">
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Clôture</th>
                <th>SMA 50</th>
                <th>SMA 200</th>
                <th>RSI 14</th>
                <th>Drawdown 52w</th>
                <th>Entry Score</th>
                <th>Entry Signal</th>
                <th>Exit Score</th>
                <th>Exit Signal</th>
                <th>Raison principale sortie</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>@row.Date</td>
                <td>@row.Close.ToString("F2")</td>
                <td>@(row.Sma50?.ToString("F2") ?? "N/A")</td>
                <td>@(row.Sma200?.ToString("F2") ?? "N/A")</td>
                <td>@(row.Rsi14?.ToString("F2") ?? "N/A")</td>
                <td>@(row.Drawdown52WeeksPercent?.ToString("F2") ?? "N/A")%</td>
                <td>@(row.Score?.ToString() ?? "N/A")</td>
                <td>
                    <div class="signal-tooltip">
                        <span class="signal-trigger" tabindex="0">@row.Signal</span>
                        <partial name="_SignalTooltip" model="row.EntryTooltip" />
                    </div>
                </td>
                <td>@(row.ExitScore?.ToString() ?? "N/A")</td>
                <td>
                    <div class="signal-tooltip">
                        <span class="signal-trigger" tabindex="0">@row.ExitSignal</span>
                        <partial name="_SignalTooltip" model="row.ExitTooltip" />
                    </div>
                </td>
                <td>@row.ExitPrimaryReason</td>
            </tr>
        }
        </tbody>
    </table>
</section>
